# apps/web/.env.local.example
#
# Copiar a apps/web/.env.local para desarrollo local.
# NUNCA commitear .env.local — está en .gitignore.
#
# Estas variables se inyectan en el bundle de Vite en build time.
# Sin ellas, los snippets de tags generan URLs con el host del browser
# en lugar de apuntar al API correcto.

# URL base del API — sin trailing slash, sin /v1
VITE_API_BASE_URL=https://api-staging.duskplatform.co

# URL base para serving de tags (display/.html, .js, tracker)
# Debe apuntar al mismo host que VITE_API_BASE_URL.
# Si no se setea, el fallback es VITE_API_BASE_URL.
VITE_TAGS_BASE_URL=https://api-staging.duskplatform.co

# URL del portal de autenticación
VITE_PORTAL_URL=https://portal-staging.duskplatform.co

# URL del Studio
VITE_STUDIO_URL=https://studio-staging.duskplatform.co

# URL de assets CDN
VITE_ASSETS_BASE_URL=https://cdn-staging.duskplatform.co

# Entorno
VITE_APP_ENV=staging
