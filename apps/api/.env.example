APP_NAME=smx-studio-api
APP_ENV=development
APP_ORIGIN=http://localhost:5173
PORT=8080
DATABASE_URL=postgres://user:password@db-host:25060/defaultdb?sslmode=require
DATABASE_POOL_URL=postgres://user:password@db-pool-host:25061/defaultdb?sslmode=require
SESSION_SECRET=replace-me
ASSETS_PUBLIC_BASE_URL=https://assets.example.com
APP_GIT_SHA=dev
APP_BUILD_TIME=2026-04-13T00:00:00Z
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=smx-assets
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me

# Worker / maintenance
DRAFT_RETENTION_DAYS=30
TRANSCODE_VIDEO_ENABLED=false
FFMPEG_BIN=ffmpeg
