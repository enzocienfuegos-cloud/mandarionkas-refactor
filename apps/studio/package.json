{
  "name": "@smx/studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/vite/dist/node/cli.js --port 5174",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.app.json --noEmit",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "build": "npm run lint && npm run build:runtime && node ../../node_modules/typescript/bin/tsc -p tsconfig.app.json --noEmit && node ../../node_modules/vite/dist/node/cli.js build",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "audit:animation-engine-surface": "npx ts-prune -p tsconfig.app.json | rg 'motion/animation-engine|export/runtime|motion-engine.ts|animation-clocks.ts|animation-events.ts|runtime-script.ts'",
    "lint": "npm run lint:css && npm run lint:colors && npm run lint:playback-live && npm run lint:broad-store && npm run audit:orphans",
    "audit:orphans": "node ./scripts/audit-orphan-components.mjs",
    "audit:visual-debt": "node ./scripts/audit-visual-debt.mjs",
    "audit:visual-debt:ratchet": "node ./scripts/audit-visual-debt.mjs --ratchet",
    "release:readiness": "node ./scripts/release-readiness-dashboard.mjs",
    "lint:css": "node ../../node_modules/stylelint/bin/stylelint.mjs 'src/**/*.css'",
    "lint:colors": "node ./scripts/lint-color-literals.mjs",
    "lint:playback-live": "node ./scripts/lint-playback-live-usage.mjs",
    "lint:broad-store": "node ./scripts/lint-broad-store-subscriptions.mjs",
    "lint:css:fix": "node ../../node_modules/stylelint/bin/stylelint.mjs 'src/**/*.css' --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@smx/contracts": "1.0.0",
    "@smx/vast": "1.0.0",
    "@types/leaflet": "^1.9.21",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "use-sync-external-store": "^1.2.2",
    "video.js": "^8.23.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/react-test-renderer": "^18.3.1",
    "@types/video.js": "^7.3.58",
    "@vitejs/plugin-react": "^4.3.1",
    "react-test-renderer": "^18.3.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-declaration-strict-value": "^1.10.11",
    "terser": "^5.47.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
