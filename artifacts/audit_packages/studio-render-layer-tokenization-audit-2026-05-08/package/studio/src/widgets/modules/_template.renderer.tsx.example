// render-tokenized: brand/theme split enforced by lint-color-literals.mjs
import type { CSSProperties } from 'react';
import type { RenderContext } from '../../canvas/stage/render-context';
import type { WidgetNode } from '../../domain/document/types';
import { moduleShell } from './shared-styles';

const exampleBrandPalette = {
  primary: '#000000',
  secondary: '#ffffff',
} as const;

const exampleChromeStyle: CSSProperties = {
  position: 'absolute',
  inset: 0,
  background: 'var(--surface-shell-overlay)',
  border: '1px solid var(--border-subtle)',
  color: 'var(--text-on-media-strong)',
  boxShadow: 'var(--shadow-text-on-media)',
};

function buildExampleShellStyle(node: WidgetNode, ctx: RenderContext): CSSProperties {
  return {
    ...moduleShell(node, ctx),
    overflow: 'hidden',
    background: 'var(--neutral-black)',
  };
}

export function ExampleRenderer({
  node,
  ctx,
}: {
  node: WidgetNode;
  ctx: RenderContext;
}): JSX.Element {
  return (
    <div style={buildExampleShellStyle(node, ctx)}>
      <div style={exampleChromeStyle}>
        Replace this with widget content.
      </div>
      <div
        style={{
          position: 'absolute',
          left: 12,
          top: 12,
          color: exampleBrandPalette.secondary,
          background: exampleBrandPalette.primary,
        }}
      >
        Brand literals stay in the brand palette.
      </div>
    </div>
  );
}
