VITE_API_BASE_URL=https://api.example.com
# Optional service-specific overrides. Leave unset when every frontend API call shares the same origin.
# VITE_PLATFORM_API_BASE_URL=https://platform.example.com
# VITE_PROJECT_API_BASE_URL=https://projects.example.com
# VITE_DOCUMENT_API_BASE_URL=https://documents.example.com
# VITE_ASSET_API_BASE_URL=https://assets.example.com

# Backend cookie/cors hardening for cloud deployments.
# PLATFORM_ALLOWED_ORIGIN=https://app.example.com
# PLATFORM_COOKIE_SECURE=true
# PLATFORM_OBSERVABILITY_ENABLED=true
# PLATFORM_LOGIN_RATE_LIMIT_WINDOW_MS=60000
# PLATFORM_LOGIN_RATE_LIMIT_MAX=10
# PLATFORM_UPLOAD_RATE_LIMIT_WINDOW_MS=60000
# PLATFORM_UPLOAD_RATE_LIMIT_MAX=20
# PLATFORM_DRAFT_RETENTION_DAYS=14
# ASSET_HOUSEKEEPING_MODE=report

# Backend repository driver.
# PLATFORM_REPOSITORY_DRIVER=postgres

# PostgreSQL repository settings.
# PLATFORM_POSTGRES_URL=postgres://user:password@db.example.com:5432/dusk
# PLATFORM_POSTGRES_SCHEMA=public
# PLATFORM_POSTGRES_SSL_MODE=prefer

# PostgreSQL activation flow:
# 1. npm run db:postgres:migrate
# 2. npm run db:postgres:ready
# 3. PLATFORM_REPOSITORY_DRIVER=postgres npm run platform:api

# Optional staging cutover assertions for smoke/post-deploy scripts.
# STAGING_EXPECTED_REPOSITORY_DRIVER=postgres
# SMOKE_EXPECTED_REPOSITORY_DRIVER=postgres
# STAGING_TENANT_MUTATION_REHEARSAL_ALLOW=false
# STAGING_TENANT_MUTATION_REHEARSAL_PREFIX=smoke-tenant
# STAGING_TENANT_MUTATION_REHEARSAL_INVITE_DOMAIN=example.invalid
# STAGING_ACCEPTANCE_DOMAINS=platform,auth_session,clients_workspaces,projects_versions,drafts_documents,assets_uploads,admin_observability_audit
# STAGING_ACCEPTANCE_INCLUDE_UPLOAD_COMPLETION=false
# SMOKE_BASE_URL=https://api.example.com
# SMOKE_LOGIN_EMAIL=admin@example.com
# SMOKE_LOGIN_PASSWORD=replace-me

# Optional snapshot scripts.
# PLATFORM_SNAPSHOT_OUT=./tmp/platform-snapshot.json
# PLATFORM_SNAPSHOT_LEFT=./tmp/platform-before.json
# PLATFORM_SNAPSHOT_RIGHT=./tmp/postgres-snapshot.json
