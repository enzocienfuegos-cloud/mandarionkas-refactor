# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://smx:smxpassword@localhost:5432/smx_studio

POSTGRES_USER=smx
POSTGRES_PASSWORD=smxpassword
POSTGRES_DB=smx_studio
POSTGRES_PORT=5432

# Connection pool
DB_POOL_MAX=10
DB_IDLE_MS=30000
DB_CONN_MS=5000
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── API server ───────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# IMPORTANT: change before deploying to production
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Max upload size in bytes (default 100 MB)
MAX_UPLOAD_BYTES=104857600

# ─── Storage ──────────────────────────────────────────────────────────────────
# 'local' stores files in ./uploads; 's3' uses AWS S3
STORAGE_DRIVER=local
UPLOADS_DIR=./uploads

# S3 (only needed when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Geo / MaxMind ────────────────────────────────────────────────────────────
# Path to GeoLite2-City.mmdb (download from maxmind.com or use geoipupdate)
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# ─── Web (frontend) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000

# ─── Email (optional — for notifications) ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@smxstudio.io

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4

# ─── Ports (docker-compose) ───────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000
