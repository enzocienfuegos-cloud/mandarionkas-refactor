VITE_API_BASE_URL=https://api-staging.example.com
VITE_AD_SERVER_URL=https://app-staging.example.com
VITE_STUDIO_URL=https://studio-staging.example.com
VITE_PORTAL_URL=https://portal-staging.example.com
SMOKE_BASE_URL=https://api-staging.example.com
SMOKE_LOGIN_EMAIL=admin@smx.studio
SMOKE_LOGIN_PASSWORD=replace-me
STAGING_EXPECTED_REPOSITORY_DRIVER=postgres
SMOKE_EXPECTED_REPOSITORY_DRIVER=postgres
STAGING_TENANT_MUTATION_REHEARSAL_ALLOW=false
STAGING_TENANT_MUTATION_REHEARSAL_PREFIX=smoke-tenant
STAGING_TENANT_MUTATION_REHEARSAL_INVITE_DOMAIN=example.invalid
STAGING_ACCEPTANCE_DOMAINS=platform,auth_session,clients_workspaces,projects_versions,drafts_documents,assets_uploads,admin_observability_audit
STAGING_ACCEPTANCE_INCLUDE_UPLOAD_COMPLETION=true
PLATFORM_SNAPSHOT_OUT=./tmp/staging-platform-snapshot.json

# Backend network/cors
PLATFORM_API_HOST=0.0.0.0
PLATFORM_API_PORT=8787
PLATFORM_ALLOWED_ORIGIN=https://portal-staging.example.com
PLATFORM_COOKIE_SECURE=true
PLATFORM_OBSERVABILITY_ENABLED=true
PLATFORM_LOGIN_RATE_LIMIT_WINDOW_MS=60000
PLATFORM_LOGIN_RATE_LIMIT_MAX=10
PLATFORM_UPLOAD_RATE_LIMIT_WINDOW_MS=60000
PLATFORM_UPLOAD_RATE_LIMIT_MAX=20
PLATFORM_DRAFT_RETENTION_DAYS=14
ASSET_HOUSEKEEPING_MODE=report

# PostgreSQL cutover
PLATFORM_REPOSITORY_DRIVER=postgres
PLATFORM_POSTGRES_URL=postgres://user:password@db-staging.example.com:5432/dusk
PLATFORM_POSTGRES_SCHEMA=public
PLATFORM_POSTGRES_SSL_MODE=require

# R2 stays binary storage only
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=your-bucket
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE=https://cdn-staging.example.com
ASSET_SIGNED_URL_TTL_SECONDS=900
