{
  "name": "smx-studio-v4",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/vite/dist/node/cli.js build",
    "preview": "node node_modules/vite/dist/node/cli.js preview",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "typecheck": "node node_modules/typescript/lib/tsc.js --project tsconfig.app.json --noEmit",
    "build:cli": "node node_modules/vite/dist/node/cli.js build",
    "test:architecture": "node node_modules/vitest/vitest.mjs run src/testing/architecture/architecture-guardrails.test.ts",
    "check": "npm run check:layers && npm run typecheck && npm run test && npm run build:cli",
    "check:layers": "npm run test:architecture",
    "inspect:layers": "node -e \"import('./src/testing/architecture/layer-rules.ts').then(() => console.log('Layer rules loaded'))\"",
    "platform:api": "node --env-file=.env server/server.mjs",
    "r2:test": "node --env-file=.env r2-test.mjs",
    "release:check": "node scripts/run-release-checks.mjs",
    "release:package": "node scripts/package-release.mjs",
    "github:build-upload": "node scripts/prepare-github-build-upload.mjs",
    "ci:verify": "npm run repo:policy && npm run release:check && npm run release:package",
    "repo:policy": "node scripts/verify-repo-policy.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "use-sync-external-store": "^1.2.2",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
