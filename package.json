{
  "name": "smx-studio-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
  "node": "20.x"
}

  "scripts": {
    "dev:web": "npm run dev -w @smx/web",
    "dev:api": "npm run dev -w @smx/api",
    "dev:worker": "npm run dev -w @smx/worker",
    "build:web": "npm run build -w @smx/web",
    "typecheck:web": "npm run typecheck -w @smx/web",
    "test:web": "npm run test -w @smx/web",
    "check:web": "npm run check -w @smx/web",
    "check": "npm run check:web",
    "db:status": "node packages/db/scripts/print-migrations.mjs",
    "start:api": "npm run start -w @smx/api",
    "start:worker": "npm run start -w @smx/worker",
    "db:migrate": "node packages/db/scripts/run-migrations.mjs",
    "db:seed:demo": "node packages/db/scripts/seed-demo-data.mjs",
    "db:import:legacy": "node packages/db/scripts/import-legacy-data.mjs",
    "check:api": "bash -lc 'find apps/api/src packages/db/src apps/worker/src scripts -name \"*.mjs\" -print0 | xargs -0 -n1 node --check'",
    "smoke:api": "node scripts/smoke-check.mjs"
  }
}
