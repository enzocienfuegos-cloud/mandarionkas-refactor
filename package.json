{
  "name": "dusk",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node node_modules/vite/dist/node/cli.js build",
    "preview": "node node_modules/vite/dist/node/cli.js preview",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "typecheck": "node node_modules/typescript/lib/tsc.js --project tsconfig.app.json --noEmit",
    "build:cli": "node node_modules/vite/dist/node/cli.js build",
    "test:architecture": "node node_modules/vitest/vitest.mjs run src/testing/architecture/architecture-guardrails.test.ts server/testing/backend-architecture.test.mjs",
    "check": "npm run check:layers && npm run typecheck && npm run test && npm run build:cli",
    "check:layers": "npm run test:architecture",
    "inspect:layers": "node -e \"import('./src/testing/architecture/layer-rules.ts').then(() => console.log('Layer rules loaded'))\"",
    "platform:api": "node --env-file=.env server/server.mjs",
    "platform:snapshot:export": "node scripts/export-platform-snapshot.mjs",
    "platform:snapshot:compare": "node scripts/compare-platform-snapshots.mjs",
    "platform:snapshot:smoke": "node scripts/platform-snapshot-smoke.mjs",
    "production:readiness:report": "node scripts/production-readiness-report.mjs",
    "production:readiness:evaluate": "node scripts/production-readiness-evaluation.mjs",
    "staging:cutover:plan": "node scripts/staging-cutover-plan.mjs",
    "staging:cutover:checklist": "node scripts/staging-cutover-checklist.mjs",
    "db:postgres:migrate": "node scripts/run-postgres-migrations.mjs",
    "db:postgres:ready": "node scripts/check-postgres-readiness.mjs",
    "db:postgres:smoke": "node scripts/postgres-smoke.mjs",
    "db:postgres:preflight": "node scripts/check-postgres-cutover-env.mjs",
    "staging:env:check": "node scripts/check-staging-env-readiness.mjs",
    "staging:platform:smoke": "node scripts/staging-platform-smoke.mjs",
    "staging:acceptance:matrix": "node scripts/staging-acceptance-matrix.mjs",
    "staging:post-deploy:check": "node scripts/staging-post-deploy-check.mjs",
    "staging:upload-completion:rehearsal": "node scripts/staging-upload-completion-rehearsal.mjs",
    "staging:tenant-mutations:rehearsal": "node scripts/staging-tenant-mutations-rehearsal.mjs",
    "staging:maintenance:cleanup-sessions": "node scripts/run-session-cleanup.mjs",
    "staging:maintenance:cleanup-drafts": "node scripts/run-draft-cleanup.mjs",
    "staging:maintenance:assets": "node scripts/run-asset-housekeeping.mjs",
    "r2:test": "node --env-file=.env r2-test.mjs",
    "release:check": "node scripts/run-release-checks.mjs",
    "release:package": "node scripts/package-release.mjs",
    "github:build-upload": "node scripts/prepare-github-build-upload.mjs",
    "ci:verify": "npm run repo:policy && npm run release:check && npm run release:package",
    "repo:policy": "node scripts/verify-repo-policy.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "use-sync-external-store": "^1.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "pg-mem": "^3.0.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
